# Database
DATABASE_URL=postgresql+asyncpg://iam_user:iam_password@db:5432/iam_db
DATABASE_URL_SYNC=postgresql://iam_user:iam_password@db:5432/iam_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — замените на случайную строку 32+ символов
JWT_SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (Password Vault) — 32 байта hex
VAULT_MASTER_KEY=change-me-to-a-random-32-byte-hex-key

# MFA
MFA_ISSUER=IAM Portal

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# App
APP_NAME=Единый портал доступа
DEBUG=true

# OIDC / IdP
OIDC_ISSUER=http://backend:8000
OIDC_INTERNAL_BASE=http://backend:8000
OIDC_EXTERNAL_BASE=https://localhost:8444
OIDC_KEY_ID=iam-key-1
OIDC_ID_TOKEN_TTL=3600
OIDC_ACCESS_TOKEN_TTL=3600
OIDC_REFRESH_TOKEN_TTL=86400

# RSA Private Key для подписи ID-токенов (RS256)
# Сгенерировать: openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt
OIDC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...вставьте свой ключ...
-----END PRIVATE KEY-----"
